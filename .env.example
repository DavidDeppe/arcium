# Arcium Environment Configuration
# Copy this file to .env and fill in your values

# Anthropic API Key (required for ReactAgent)
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Development Mode (optional, defaults to false)
# When true: uses Haiku model (12x cheaper) and limits to 5 steps
# When false/unset: uses Sonnet model (higher quality) and allows 10 steps
DEV_MODE=true

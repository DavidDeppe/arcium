# Arcium Environment Configuration
# Copy this file to .env and fill in your values

# Anthropic API Key (required for ARCIUM_EXECUTION_MODE=api)
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Development Mode (optional, defaults to false)
# When true: uses Haiku model (12x cheaper) and limits to $2 cost cap
# When false/unset: uses Sonnet model (higher quality) and allows $10 cost cap
# NOTE: DEV_MODE only affects API cost tracking. In autonomous mode all agents
#       run via Claude Code CLI so no API credits are consumed.
DEV_MODE=true

# Execution Mode (optional, defaults to autonomous)
#
# autonomous — All five agents run via ClaudeCodeAgent (claude --print subprocess).
#              Requires: Claude Code CLI installed + Claude Max or Pro subscription.
#              Benefit: No API credits consumed; handles long multi-step tasks well.
#              Tradeoff: Requires local Claude Code installation; slightly slower startup.
#
# api        — All five agents run via ReactAgent using the Anthropic SDK directly.
#              Requires: ANTHROPIC_API_KEY set above with sufficient credits.
#              Benefit: Works anywhere Python runs; no local CLI dependency.
#              Tradeoff: Consumes API credits; may hit rate limits on large tasks.
#
ARCIUM_EXECUTION_MODE=autonomous
